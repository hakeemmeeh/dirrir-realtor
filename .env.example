NEXT_PUBLIC_SITE_URL=https://dirrirrealtor.co.ke
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# Resend (https://resend.com) — contact & property enquiry emails
RESEND_API_KEY=
# Must be a verified sender, e.g. Dirrir <onboarding@resend.dev> in dev or your domain in production
RESEND_FROM_EMAIL=
# Comma-separated inbox(es) for lead notifications
CONTACT_TO_EMAIL=

# Sanity CMS — when set, listings load from Sanity; otherwise local fallback data is used
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: override default /brochures/dirrir-portfolio.pdf
NEXT_PUBLIC_BROCHURE_URL=/brochures/dirrir-portfolio.pdf
